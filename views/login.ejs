<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DIPOSEAT | Admin Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --bg-body: #F4F7FE;
            --white: #FFFFFF;
            --text-main: #1B2559;
            --text-muted: #A3AED0;

            /* Palet Warna Pastel Request */
            --primary: #6367FF;
            --secondary: #8494FF;
            --pastel-blue: #C9BEFF;
            --pastel-pink: #FFDBFD;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-body);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-card {
            background: var(--white);
            padding: 50px 40px;
            border-radius: 30px;
            box-shadow: 0 20px 50px rgba(99, 103, 255, 0.05);
            width: 100%;
            max-width: 420px;
            text-align: center;
        }

        .brand-logo {
            font-weight: 800;
            font-size: 2.2rem;
            color: var(--primary);
            letter-spacing: -1.5px;
            margin-bottom: 8px;
        }

        .login-subtitle {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin-bottom: 40px;
        }

        .form-group {
            text-align: left;
            margin-bottom: 22px;
        }

        .form-label {
            font-weight: 700;
            font-size: 0.85rem;
            color: var(--text-main);
            margin-bottom: 10px;
            display: block;
            margin-left: 4px;
        }

        .input-group-custom {
            position: relative;
        }

        .form-control {
            border-radius: 16px;
            padding: 14px 18px;
            border: 1px solid #E0E5F2;
            background: #F4F7FE;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            width: 100%;
            color: var(--text-main);
        }

        .form-control:focus {
            border-color: var(--secondary);
            background: white;
            box-shadow: 0 4px 12px rgba(99, 103, 255, 0.05);
            outline: none;
        }

        /* Password Toggle */
        .toggle-password {
            position: absolute;
            right: 18px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: var(--text-muted);
            font-size: 1.2rem;
            z-index: 10;
            transition: 0.2s;
        }

        .toggle-password:hover {
            color: var(--primary);
        }

        /* Button Sign In - Pastel Blue */
        .btn-sign-in {
            background-color: var(--pastel-blue);
            color: white;
            border: none;
            border-radius: 18px;
            padding: 16px;
            font-weight: 800;
            font-size: 1rem;
            width: 100%;
            margin-top: 15px;
            transition: all 0.3s ease;
            box-shadow: 0 10px 20px rgba(201, 190, 255, 0.3);
        }

        .btn-sign-in:hover {
            background-color: var(--secondary);
            transform: translateY(-3px);
            box-shadow: 0 12px 25px rgba(132, 148, 255, 0.4);
        }

        /* Error Alert */
        .alert-custom {
            background-color: #FFF5F5;
            color: #EE5D50;
            border-radius: 15px;
            padding: 12px;
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 25px;
            border: 1px solid rgba(238, 93, 80, 0.1);
        }
    </style>
</head>

<body>

    <div class="login-card">
        <div class="brand-logo">DIPOSEAT</div>
        <p class="login-subtitle">Masukkan kredensial untuk akses dashboard.</p>

        <% if (messages.error) { %>
            <div class="alert-custom">
                <i class="bi bi-exclamation-circle-fill me-2"></i>
                <%= messages.error %>
            </div>
            <% } %>

                <form action="/login" method="POST">
                    <div class="form-group">
                        <label class="form-label">Username atau Email</label>
                        <input type="text" name="username" class="form-control"
                            placeholder="Masukkan username atau email Anda" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <div class="input-group-custom">
                            <input type="password" id="passwordInput" name="password" class="form-control"
                                placeholder="Masukkan password Anda" required>
                            <i class="bi bi-eye-slash toggle-password" id="toggleIcon"></i>
                        </div>
                    </div>

                    <button type="submit" class="btn-sign-in">Sign In</button>
                </form>
    </div>

    <script>
        const togglePassword = document.querySelector('#toggleIcon');
        const passwordInput = document.querySelector('#passwordInput');

        togglePassword.addEventListener('click', function () {
            // Cek tipe saat ini
            const isPassword = passwordInput.getAttribute('type') === 'password';

            // Toggle tipe input
            passwordInput.setAttribute('type', isPassword ? 'text' : 'password');

            // Toggle icon
            this.classList.toggle('bi-eye');
            this.classList.toggle('bi-eye-slash');
        });
    </script>

</body>

</html>