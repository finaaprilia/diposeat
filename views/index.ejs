<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DIPOSEAT | Chill & Work Hub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --pastel-blue: #E3F2FD;
            --soft-indigo: #1A237E;
            --main-bg: #FFFFFF;
            --card-bg: #F0F7FF;
        }

        body {
            background-color: var(--main-bg);
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #455A64;
            scroll-behavior: smooth;
        }

        .hero-section {
            background: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)),
                url('/images/caffe.jpeg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            color: white;
            padding: 80px 0 60px 0;
            min-height: 300px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            border-radius: 0 0 40px 40px;
            text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.6);
            border-bottom: 4px solid var(--pastel-blue);
        }

        .hero-section h1 {
            font-size: 3.5rem;
            font-weight: 800;
            letter-spacing: -2px;
            margin-bottom: 5px;
        }

        .info-section {
            padding: 60px 0;
            text-align: center;
        }

        .vibe-card {
            background: #F8F9FA;
            border-radius: 20px;
            padding: 25px;
            height: 100%;
            transition: 0.3s;
        }

        .btn-main {
            background-color: var(--soft-indigo);
            color: white;
            padding: 12px 35px;
            border-radius: 30px;
            font-weight: 700;
            border: none;
            transition: 0.3s;
        }

        .btn-main:hover {
            transform: scale(1.05);
            background-color: #3949AB;
            color: white;
        }

        .menu-slider-card {
            background-color: var(--card-bg);
            border: none;
            border-radius: 30px;
            overflow: hidden;
            max-width: 900px;
            margin: 0 auto;
        }

        .menu-image-container {
            height: 350px;
            overflow: hidden;
        }

        .menu-image-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .menu-category {
            font-size: 0.8rem;
            font-weight: 700;
            color: #1E88E5;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .carousel-control-prev-icon,
        .carousel-control-next-icon {
            background-color: var(--soft-indigo);
            border-radius: 50%;
            padding: 20px;
            background-size: 50%;
        }

        #reservation-area {
            display: none;
            padding: 60px 0;
            background-color: #FDFDFD;
        }

        .card-meja {
            border: 1px solid #E3F2FD;
            border-radius: 24px;
            transition: all 0.3s ease;
            background-color: var(--card-bg);
        }

        .card-meja:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 20px rgba(26, 35, 126, 0.05) !important;
            border-color: #BBDEFB;
        }

        .status-badge {
            background-color: white;
            color: #1E88E5;
            font-weight: 600;
            border-radius: 12px;
            padding: 4px 12px;
            font-size: 0.8rem;
            border: 1px solid #E3F2FD;
        }

        .btn-booking {
            background-color: white;
            color: var(--soft-indigo);
            border: 2px solid var(--soft-indigo);
            border-radius: 15px;
            font-weight: 700;
            transition: 0.2s;
        }

        .btn-booking:hover {
            background-color: var(--soft-indigo);
            color: white;
        }
    </style>
</head>

<body>
    <% if (user) { %>
        <div style="position: absolute; top: 20px; right: 30px; z-index: 1000;"
            class="bg-white p-2 px-3 rounded-pill shadow-sm">
            <span class="small text-muted">Halo, <b>
                    <%= user.username %>
                </b></span>

            <span class="mx-2 text-muted">|</span>
            <a href="/my-reservations" class="text-primary small fw-bold text-decoration-none">Reservasi Saya</a>

            <span class="mx-2 text-muted">|</span>
            <a href="/logout" class="text-danger small fw-bold text-decoration-none">Logout</a>
        </div>
        <% } %>

            <div class="hero-section text-center">
                <div class="container">
                    <h1>DIPOSEAT</h1>
                    <p>Your Ultimate Spot to Study, Chill, and Connect in Tembalang.</p>
                </div>
            </div>

            <div class="container info-section">
                <div class="row justify-content-center mb-5">
                    <div class="col-md-8">
                        <h2 class="fw-bold mb-3">Gak Cuma Sekedar Caffe ☕</h2>
                        <p class="text-muted mb-4">
                            Third place paling asik buat nugas atau sekedar nongkrong. WiFi kenceng, ambience tenang,
                            dan yang paling penting:
                            <strong>Pesan meja duluan, nugas kemudian!</strong>
                        </p>

                        <% if (!user) { %>
                            <button data-bs-toggle="modal" data-bs-target="#authModal" class="btn-main shadow">Amankan
                                Meja</button>
                            <% } else { %>
                                <button onclick="showTables()" class="btn-main shadow">Amankan Meja</button>
                                <% } %>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="vibe-card">
                            <h4>⚡ High-Speed</h4>
                            <p class="small text-muted m-0">WiFi aman buat kelarin tugas.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="vibe-card">
                            <h4>🍃 Chill Vibe</h4>
                            <p class="small text-muted m-0">Playlist lo-fi yang bikin nugas makin fokus.</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="vibe-card">
                            <h4>🤝 Hub</h4>
                            <p class="small text-muted m-0">Meja panjang buat rapat atau kerja kelompok.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="container py-5">
                <div class="text-center mb-5">
                    <h3 class="fw-bold">Favorit Mahasiswa 🥐</h3>
                    <p class="text-muted">Geser untuk melihat menu peneman nugas paling chill.</p>
                </div>

                <div id="menuCarousel" class="carousel slide shadow-sm" data-bs-ride="carousel"
                    style="border-radius: 30px; overflow: hidden;">
                    <div class="carousel-inner">
                        <div class="carousel-item active">
                            <div class="card menu-slider-card">
                                <div class="row g-0 align-items-center">
                                    <div class="col-md-6 menu-image-container">
                                        <img src="/images/caramelmacchiato.jpeg" alt="Coffee">
                                    </div>
                                    <div class="col-md-6 p-5">
                                        <span class="fw-bold text-primary small text-uppercase">Coffee Selection</span>
                                        <h3 class="fw-bold text-dark mt-2">Caramel Macchiato</h3>
                                        <p class="text-muted">Perpaduan espresso dan karamel yang bikin melek pas
                                            deadline.</p>
                                        <h4 class="mt-4 text-indigo fw-bold">Rp 25.000</h4>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="carousel-item">
                            <div class="card menu-slider-card">
                                <div class="row g-0 align-items-center">
                                    <div class="col-md-6 menu-image-container">
                                        <img src="https://images.unsplash.com/photo-1555507036-ab1f4038808a?q=80&w=1000&auto=format&fit=crop"
                                            alt="Pastry">
                                    </div>
                                    <div class="col-md-6 p-5">
                                        <span class="menu-category">Freshly Baked</span>
                                        <h3 class="fw-bold text-dark mt-2">Butter Croissant</h3>
                                        <p class="text-muted">Flaky, buttery, dan fresh banget setiap hari.</p>
                                        <h4 class="menu-price mt-4">Rp 18.000</h4>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#menuCarousel"
                        data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#menuCarousel"
                        data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    </button>
                </div>
            </div>

            <div id="reservation-area">
                <div class="container">
                    <div class="text-center mb-5">
                        <h3 class="fw-bold">Pilih Spot Favoritmu</h3>
                        <p class="text-muted">Klik "Tempatin" untuk amankan kursimu.</p>
                    </div>
                    <div class="row">
                        <% tables.forEach((table)=> { %>
                            <div class="col-md-4 col-lg-3 mb-4">
                                <div class="card h-100 shadow-sm card-meja">
                                    <div class="card-body p-4 text-center">
                                        <% if (table.status==='occupied' ) { %>
                                            <span
                                                class="status-badge d-inline-block mb-3 bg-secondary text-white">Terisi</span>
                                            <h5 class="fw-bold mb-2">Meja <%= table.table_number %>
                                            </h5>
                                            <button disabled class="btn btn-secondary w-100 py-2">Terisi</button>
                                            <% } else { %>
                                                <span class="status-badge d-inline-block mb-3">Tersedia</span>
                                                <h5 class="fw-bold mb-2">Meja <%= table.table_number %>
                                                </h5>
                                                <p class="small mb-4 text-muted">Kapasitas <%= table.capacity %> Kursi
                                                </p>
                                                <button
                                                    onclick="openBookingModal('<%= table.id %>', '<%= table.table_number %>')"
                                                    class="btn btn-booking w-100 py-2">Tempatin</button>
                                                <% } %>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                </div>
            </div>

            <footer class="text-center py-5">
                <p class="text-muted small">&copy; 2026 DIPOSEAT - Crafting Comfort for Students</p>
            </footer>

            <div class="modal fade" id="authModal" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content" style="border-radius: 30px; border: none;">
                        <div class="modal-body p-5">
                            <h3 class="fw-bold mb-4 text-center" id="authTitle">Login ke DIPOSEAT</h3>

                            <form id="loginForm" action="/login" method="POST">
                                <input type="text" name="username" class="form-control mb-3"
                                    placeholder="Username atau Email" required>
                                <input type="password" name="password" class="form-control mb-3" placeholder="Password"
                                    required>
                                <button type="submit" class="btn-main w-100 mb-3">Masuk</button>
                                <p class="text-center small">Belum punya akun? <a href="#" onclick="toggleAuth()">Daftar
                                        di sini</a></p>
                            </form>

                            <form id="regForm" action="/register" method="POST" style="display: none;">
                                <input type="text" name="username" class="form-control mb-3" placeholder="Username"
                                    required>
                                <input type="email" name="email" class="form-control mb-3" placeholder="Email" required>
                                <input type="password" name="password" class="form-control mb-3" placeholder="Password"
                                    required>
                                <button type="submit" class="btn-main w-100 mb-3">Buat Akun</button>
                                <p class="text-center small">Sudah punya akun? <a href="#" onclick="toggleAuth()">Login
                                        aja</a></p>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="bookingModal" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content" style="border-radius: 25px;">
                        <div class="modal-header border-0">
                            <h5 class="fw-bold">Detail Reservasi - Meja <span id="modalTableNum"></span></h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <form id="reservationForm">
                                <input type="hidden" id="tableId">
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">Nama Lengkap</label>
                                    <input type="text" class="form-control" id="resName"
                                        value="<%= user ? user.username : '' %>" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label small fw-bold">No. Telepon (WhatsApp)</label>
                                    <input type="tel" class="form-control" id="resPhone" placeholder="0812..." required>
                                </div>
                                <div class="row">
                                    <div class="col-6 mb-3">
                                        <label class="form-label small fw-bold">Tanggal</label>
                                        <input type="date" class="form-control" id="resDate" required>
                                    </div>
                                    <div class="col-6 mb-3">
                                        <label class="form-label small fw-bold">Jam</label>
                                        <input type="time" class="form-control" id="resTime" required>
                                    </div>
                                </div>
                                <button type="submit" class="btn-main w-100 mt-3">Simpan Reservasi</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                function showTables() {
                    const area = document.getElementById('reservation-area');
                    area.style.display = 'block';
                    window.scrollTo({ top: area.offsetTop, behavior: 'smooth' });
                }

                function toggleAuth() {
                    const logForm = document.getElementById('loginForm');
                    const regForm = document.getElementById('regForm');
                    const title = document.getElementById('authTitle');
                    if (logForm.style.display === 'none') {
                        logForm.style.display = 'block';
                        regForm.style.display = 'none';
                        title.innerText = 'Login ke DIPOSEAT';
                    } else {
                        logForm.style.display = 'none';
                        regForm.style.display = 'block';
                        title.innerText = 'Daftar Akun Baru';
                    }
                }

                function openBookingModal(id, num) {
                    document.getElementById('tableId').value = id;
                    document.getElementById('modalTableNum').innerText = num;
                    new bootstrap.Modal(document.getElementById('bookingModal')).show();
                }

                // Logic Reservasi
                document.getElementById('reservationForm').onsubmit = async (e) => {
                    e.preventDefault();
                    const tableId = document.getElementById('tableId').value;
                    const data = {
                        reserved_by: document.getElementById('resName').value,
                        phone: document.getElementById('resPhone').value,
                        reservation_date: document.getElementById('resDate').value,
                        reservation_time: document.getElementById('resTime').value
                    };

                    const res = await fetch(`/user/book-table/${tableId}`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });

                    if (res.ok) {
                        alert('Reservasi Berhasil!');
                        location.reload();
                    } else {
                        alert('Gagal melakukan reservasi.');
                    }
                };
            </script>
</body>

</html>