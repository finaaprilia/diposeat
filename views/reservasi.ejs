<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reservasi Saya | DIPOSEAT</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap"
        rel="stylesheet">
    <style>
        :root {
            --soft-indigo: #1A237E;
            /* Palette lo */
            --pastel-blue: #E3F2FD;
            --main-bg: #F8F9FA;
        }

        body {
            background-color: var(--main-bg);
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #455A64;
        }

        .navbar-mini {
            background: white;
            padding: 15px 0;
            border-bottom: 2px solid var(--pastel-blue);
            margin-bottom: 40px;
        }

        .card-res {
            background: white;
            border-radius: 25px;
            border: none;
            transition: 0.3s;
            box-shadow: 0 10px 30px rgba(26, 35, 126, 0.05);
            overflow: hidden;
        }

        .card-res:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(26, 35, 126, 0.1);
        }

        .card-header-custom {
            background-color: var(--soft-indigo);
            color: white;
            padding: 15px 25px;
            font-weight: 700;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .info-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
            color: #90A4AE;
            margin-bottom: 2px;
        }

        .info-value {
            font-weight: 600;
            color: var(--soft-indigo);
            margin-bottom: 15px;
        }

        .badge-status {
            background: #E8F5E9;
            color: #2E7D32;
            padding: 6px 15px;
            border-radius: 12px;
            font-size: 0.8rem;
            font-weight: 700;
        }

        .btn-back {
            background: var(--pastel-blue);
            color: var(--soft-indigo);
            font-weight: 700;
            border-radius: 15px;
            padding: 10px 25px;
            text-decoration: none;
            transition: 0.3s;
        }

        .btn-back:hover {
            background: var(--soft-indigo);
            color: white;
        }
    </style>
</head>

<body>

    <nav class="navbar-mini">
        <div class="container d-flex justify-content-between align-items-center">
            <h4 class="fw-bold m-0" style="color: var(--soft-indigo);">DIPOSEAT</h4>
            <a href="/" class="btn-back small">Kembali ke beranda</a>
        </div>
    </nav>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="mb-4">
                    <h2 class="fw-extrabold mb-1" style="font-weight: 800; color: #263238;">Riwayat Reservasi</h2>
                    <p class="text-muted">Halo <b>
                            <%= user.username %>
                        </b>, ini daftar meja yang sudah diamankan.</p>
                </div>

                <% if (reservations.length> 0) { %>
                    <div class="row">
                        <% reservations.forEach(res=> { %>
                            <div class="col-12 mb-4">
                                <div class="card card-res">
                                    <div class="card-header-custom">
                                        <span>MEJA <%= res.table_number %></span>
                                        <span class="badge-status">Confirmed</span>
                                    </div>
                                    <div class="card-body p-4">
                                        <div class="row">
                                            <div class="col-sm-6">
                                                <p class="info-label">Tanggal Booking</p>
                                                <p class="info-value">
                                                    <%= new Date(res.res_date).toLocaleDateString('id-ID', {
                                                        weekday: 'long' , year: 'numeric' , month: 'long' ,
                                                        day: 'numeric' }) %>
                                                </p>
                                            </div>
                                            <div class="col-sm-6">
                                                <p class="info-label">Waktu Kedatangan</p>
                                                <p class="info-value text-uppercase">
                                                    <%= res.res_time %>
                                                </p>
                                            </div>
                                            <div class="col-12">
                                                <div class="p-3 rounded-4" style="background: #F0F7FF;">
                                                    <p class="info-label m-0">Atas Nama</p>
                                                    <p class="fw-bold m-0" style="color: #1A237E;">
                                                        <%= res.reserved_by %>
                                                    </p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>

                    <div class="mt-2 p-4 rounded-4 shadow-sm border-0 bg-white mb-5">
                        <div class="d-flex align-items-center">
                            <div class="me-3">
                                <span style="font-size: 1.5rem;">ℹ️</span>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1" style="color: var(--soft-indigo);">Informasi Pembatalan</h6>
                                <p class="small text-muted mb-2">
                                    Pembatalan booking hanya dapat dilakukan melalui admin.</p>
                                <p class="mb-0 small fw-bold">
                                    Hubungi Staff:
                                    <a href="https://wa.me/6281234567890" target="_blank"
                                        class="text-success text-decoration-none">
                                        0812-3456-7890 (WhatsApp)
                                    </a>
                                </p>
                            </div>
                        </div>
                    </div>

                    <% } else { %>
                        <div class="text-center py-5 bg-white rounded-5 shadow-sm">
                            <img src="/images/empty.jpg" alt="Empty" style="width: 250px; border-radius: 20px;"
                                class="mb-4">
                            <h5 class="fw-bold">Belum ada meja yang dipesan</h5>
                            <p class="text-muted mb-4">Cari spot nugas favorit lo sekarang!</p>
                            <a href="/" class="btn btn-primary px-4 py-2 rounded-pill fw-bold">Cari Meja</a>
                        </div>
                        <% } %>
            </div>
        </div>
    </div>

    <footer class="text-center py-5">
        <p class="text-muted small">&copy; 2026 DIPOSEAT - Crafting Comfort for Students</p>
    </footer>

</body>

</html>